indicator("Complete Time & Session Dividers", "TimeDividers", overlay = true)

// === HELPER FUNCTIONS ===

// Function to format the timeframe string for labels
f_formatTimeframe(string tf) =>
    switch tf
        "1"   => "1M"
        "3"   => "3M"
        "5"   => "5M"
        "15"  => "15M"
        "30"  => "30M"
        "60"  => "1H"
        "120" => "2H"
        "180" => "3H"
        "240" => "4H"
        "D"   => "1D"
        "W"   => "1W"
        "M"   => "1M"
        => tf 

// Function to convert string input to line style
f_getLineStyle(string style) =>
    switch style
        "Dotted" => line.style_dotted
        "Dashed" => line.style_dashed
        => line.style_solid

