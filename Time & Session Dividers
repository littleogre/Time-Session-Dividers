// === LOGIC & DRAWINGS ===

// Persistent line IDs for horizontal open levels
var line lnTF1 = na, var line lnTF2 = na, var line lnTF3 = na
var line lnSL1 = na, var line lnSL2 = na, var line lnSL3 = na

// --- Timeframe Logic Processing ---
f_processTF(bool useVert, bool useHoriz, string tf, color clr, string style, bool showTxt, line lnID) =>
    line currentLine = lnID
    if useVert or useHoriz
        tf_time = time(tf, i_timezone)
        bool isNew = ta.change(tf_time) != 0
        if isNew
            if useHoriz
                line.set_x2(currentLine, bar_index) // End previous
                currentLine := line.new(bar_index, open, bar_index, open, xloc.bar_index, extend.none, clr, f_getLineStyle(style), 1)
            if useVert
                line.new(bar_index, low, bar_index, high, xloc.bar_index, extend.both, clr, f_getLineStyle(style), 1)
                if showTxt
                    label.new(bar_index, high, f_formatTimeframe(tf), xloc.bar_index, yloc.abovebar, color.new(color.white, 100), label.style_none, clr, size.normal)
        if useHoriz
            line.set_x2(currentLine, bar_index)
    currentLine

lnTF1 := f_processTF(i_useDivider1, i_showOpenLine1, i_timeframe1, i_lineColor1, i_lineStyle1, i_showText1, lnTF1)
lnTF2 := f_processTF(i_useDivider2, i_showOpenLine2, i_timeframe2, i_lineColor2, i_lineStyle2, i_showText2, lnTF2)
lnTF3 := f_processTF(i_useDivider3, i_showOpenLine3, i_timeframe3, i_lineColor3, i_lineStyle3, i_showText3, lnTF3)

// --- Time Slot Logic Processing ---
f_processSlot(bool useVert, bool useHoriz, string sess, color clr, string style, bool showTxt, line lnID) =>
    line currentLine = lnID
    if useVert or useHoriz
        bool isInSess = not na(time(timeframe.period, sess, i_timezone))
        bool isStart  = isInSess and not isInSess[1]
        bool isEnd    = not isInSess and isInSess[1]
        
        if isStart
            if useHoriz
                currentLine := line.new(bar_index, open, bar_index, open, xloc.bar_index, extend.none, clr, f_getLineStyle(style), 1)
            if useVert
                line.new(bar_index, low, bar_index, high, xloc.bar_index, extend.both, clr, f_getLineStyle(style), 1)
                if showTxt
                    label.new(bar_index, high, str.format("{0}:{1}", str.substring(sess, 0, 2), str.substring(sess, 2, 4)), xloc.bar_index, yloc.abovebar, color.new(color.white, 100), label.style_none, clr, size.normal)
        
        if isEnd
            if useHoriz
                line.set_x2(currentLine, bar_index)
            if useVert
                line.new(bar_index, low, bar_index, high, xloc.bar_index, extend.both, clr, f_getLineStyle(style), 1)
                if showTxt
                    label.new(bar_index, high, str.format("{0}:{1}", str.substring(sess, 5, 7), str.substring(sess, 7, 9)), xloc.bar_index, yloc.abovebar, color.new(color.white, 100), label.style_none, clr, size.normal)
        
        if isInSess and useHoriz
            line.set_x2(currentLine, bar_index)
    currentLine

lnSL1 := f_processSlot(i_useSlot1, i_showOpenSlot1, i_session1, i_colorSlot1, i_styleSlot1, i_showTextSlot1, lnSL1)
lnSL2 := f_processSlot(i_useSlot2, i_showOpenSlot2, i_session2, i_colorSlot2, i_styleSlot2, i_showTextSlot2, lnSL2)
lnSL3 := f_processSlot(i_useSlot3, i_showOpenSlot3, i_session3, i_colorSlot3, i_styleSlot3, i_showTextSlot3, lnSL3)
